{
  "schemaVersion": 1,
  "autoDefaults": [
    { "permission": "read", "action": "allow" },
    { "permission": "edit", "action": "allow" },
    { "permission": "shell", "action": "allow" },
    { "permission": "network", "action": "ask" },
    { "permission": "external_effect", "action": "ask" },
    { "permission": "external_directory", "action": "ask" },
    { "permission": "delete", "action": "ask" },
    { "permission": "rollback", "action": "ask" },
    { "permission": "shell_unparsed", "action": "ask" },
    { "permission": "unknown", "action": "ask" }
  ],
  "precedenceCases": [
    {
      "id": "explicit-deny-wins",
      "input": { "mode": "full-access", "permission": "shell", "explicitRule": "deny", "approvalPreference": "user" },
      "action": "deny"
    },
    {
      "id": "redline-cannot-auto-allow",
      "input": { "mode": "full-access", "permission": "shell", "absoluteRedline": true, "approvalPreference": "auto" },
      "action": "ask"
    },
    {
      "id": "hardline-cannot-explicit-allow",
      "input": { "mode": "full-access", "permission": "hardline", "explicitRule": "allow" },
      "action": "ask"
    },
    {
      "id": "user-preference-tightens-full-access",
      "input": { "mode": "full-access", "permission": "network", "approvalPreference": "user" },
      "action": "ask"
    },
    {
      "id": "explicit-allow-overrides-auto-default",
      "input": { "mode": "auto", "permission": "network", "explicitRule": "allow" },
      "action": "allow"
    }
  ],
  "dangerousCommands": [
    { "command": "git reset --hard", "permission": "delete", "riskLevel": 3 },
    { "command": "git push --force origin main", "permission": "hardline", "riskLevel": 4 },
    { "command": "git push -fu origin main", "permission": "hardline", "riskLevel": 4 },
    { "command": "git push origin +main", "permission": "hardline", "riskLevel": 4 },
    { "command": "git push --mirror origin", "permission": "hardline", "riskLevel": 4 },
    { "command": "npm publish", "permission": "network", "riskLevel": 2 },
    { "command": "cargo publish", "permission": "external_effect", "riskLevel": 2 },
    { "command": "docker run node:22 --version", "permission": "external_effect", "riskLevel": 2 },
    { "command": "gh pr create", "permission": "external_effect", "riskLevel": 2 },
    { "command": "iwr https://example.test", "permission": "network", "riskLevel": 2 }
  ],
  "shellCorpus": "../permission-shell-corpus.json"
}
