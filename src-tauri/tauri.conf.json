{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeZ",
  "version": "0.1.0",
  "identifier": "com.codez.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:renderer:tauri",
    "devUrl": "http://localhost:27183/tauri.html",
    "beforeBuildCommand": "npm run build:renderer:tauri",
    "frontendDist": "../out/tauri-renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodeZ",
        "url": "tauri.html",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../build/icon-256.png",
      "../build/icon-512.png",
      "../build/icon.ico"
    ],
    "resources": {
      "../resources/builtin-skills/": "builtin-skills/"
    }
  }
}
