{
  "name": "codez",
  "version": "0.1.0",
  "description": "Agent Coding Desktop — 基于大语言模型 API 的桌面端 Agent Coding 工具",
  "private": true,
  "scripts": {
    "dev": "tauri dev --no-watch",
    "dev:renderer:tauri": "vite --config vite.tauri.config.ts",
    "dev:tauri": "tauri dev --no-watch",
    "dev:tauri:watch": "tauri dev",
    "analyze:tauri-resources": "vite-node scripts/tauri/analyze-resource-bundle.ts",
    "build:renderer:tauri": "vite build --config vite.tauri.config.ts",
    "build:tauri": "tauri build",
    "check:architecture": "vite-node scripts/tauri/check-rust-dependencies.ts",
    "contracts:generate": "cargo run -p codez-contracts --example export_bindings",
    "check:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets --all-features -- -D warnings && cargo test --workspace --all-targets",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run build:renderer:tauri",
    "package": "tauri build"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.7",
    "@react-symbols/icons": "^1.4.1",
    "@tauri-apps/api": "^2.11.1",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.23.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^20.14.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
