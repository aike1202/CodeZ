{
  "name": "codez",
  "version": "0.1.0",
  "description": "Agent Coding Desktop — 基于大语言模型 API 的桌面端 Agent Coding 工具",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "analyze:shell-corpus": "vite-node scripts/analyze-shell-command-corpus.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder build --win --publish never"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.7",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-symbols/icons": "^1.4.1",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^8.20.0",
    "electron-log": "^5.4.4",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lodash": "^4.18.1",
    "lucide-react": "^1.23.0",
    "node-pty": "^1.1.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tree-sitter-bash": "^0.25.0",
    "tree-sitter-powershell": "^0.25.10",
    "web-tree-sitter": "^0.25.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.14.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.codez.desktop",
    "productName": "CodeZ",
    "npmRebuild": false,
    "directories": {
      "output": "dist-app"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/builtin-skills",
        "to": "builtin-skills"
      },
      {
        "from": "node_modules/web-tree-sitter/tree-sitter.wasm",
        "to": "permission-parsers/tree-sitter.wasm"
      },
      {
        "from": "node_modules/tree-sitter-bash/tree-sitter-bash.wasm",
        "to": "permission-parsers/tree-sitter-bash.wasm"
      },
      {
        "from": "node_modules/tree-sitter-powershell/tree-sitter-powershell.wasm",
        "to": "permission-parsers/tree-sitter-powershell.wasm"
      }
    ]
  }
}
